# InfluxDB Configuration
# Copy this file to .env and fill in your values

# InfluxDB Admin Credentials
DOCKER_INFLUXDB_INIT_USERNAME=your_influx_username_here
DOCKER_INFLUXDB_INIT_PASSWORD=your_influx_password_here
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=your_influx_admin_token_here

# InfluxDB Organization and Bucket
DOCKER_INFLUXDB_INIT_ORG=digital-twin
DOCKER_INFLUXDB_INIT_BUCKET=supply-chain

# InfluxDB Connection (used by Telegraf and Dashboard)
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=your_influx_token_here
INFLUX_ORG=digital-twin
INFLUX_BUCKET=supply-chain

# MQTT Broker Configuration
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# Token Generation Process:
# 1. After first startup, access InfluxDB UI at http://localhost:8086
# 2. Login with DOCKER_INFLUXDB_INIT_USERNAME and DOCKER_INFLUXDB_INIT_PASSWORD
# 3. Navigate to Data > API Tokens
# 4. The admin token will be auto-generated during initialization
# 5. You can create additional tokens with specific permissions for different services
# 6. Copy the token value and update INFLUX_TOKEN in this file
