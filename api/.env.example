# FastAPI Dashboard API Environment Variables
# Copy this to .env and update values

# InfluxDB Connection (should match main .env)
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=your_influx_token_here
INFLUX_ORG=digital-twin
INFLUX_BUCKET=supply-chain

# MQTT Broker (for WebSocket subscriptions later)
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# API Server
PORT=8000
